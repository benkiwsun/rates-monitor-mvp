DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rates_monitor
FRED_API_KEY=your_fred_api_key_here
USE_SAMPLE_FALLBACK=true
# Hourly full ingest when the API process runs (set true in production)
SCHEDULER_ENABLED=false
# If set, POST /api/v1/jobs/ingest requires header X-Ingest-Key or query ingest_key
ADMIN_INGEST_KEY=
EVENT_CALENDAR_URL=
# Optional event calendar source feeds (CSV format: date,type,country,title,importance)
# Example:
# EVENT_SOURCE_URLS_JSON={"fomc":"https://example.com/fomc.csv","us_macro":"https://example.com/us_macro.csv","cb_meeting":"https://example.com/cb_meeting.csv"}
EVENT_SOURCE_URLS_JSON={}
# Optional external CSV feeds by indicator code (format: date,value).
# Example:
# MARKET_FEED_URLS_JSON={"HIBOR_ON":"https://example.com/hibor_on.csv","SHIBOR_ON":"https://example.com/shibor_on.csv","USDCNH_SWAP_3M":"https://example.com/usdcnh_3m.csv"}
MARKET_FEED_URLS_JSON={}
